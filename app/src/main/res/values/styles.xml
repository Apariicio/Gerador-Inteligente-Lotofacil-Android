<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="EstiloBola">
        <item name="android:layout_width">45dp</item>
        <item name="android:layout_height">45dp</item>

        <item name="android:layout_margin">6dp</item>

        <item name="android:gravity">center</item>
        <item name="android:background">#CCCCCC</item>
        <item name="android:textColor">#FFFFFF</item>

        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:visibility">invisible</item>
    </style>
    <style name="MeuWidgetMenu" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@drawable/fundo_menu</item>
    </style>

    <style name="TemaMenuPremium" parent="Theme.QuinzeNúmerosAleatórios">
        <item name="popupMenuStyle">@style/MeuWidgetMenu</item>
        <item name="android:textColor">@color/texto_principal</item>
        <item name="android:colorBackground">@color/fundo_card_popup</item>
    </style>
</resources>