<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_inicial"
    android:padding="16dp">

    <TextClock
        android:id="@+id/relogioDigital"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp"
        android:format12Hour="HH:mm:ss"
        android:format24Hour="HH:mm:ss"
        android:textColor="#333333"
        android:textSize="26sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/relogioDigital"
        android:layout_marginTop="5dp"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:background="#9991E5FA"
            android:text="Toque no volante para compartilhar"
            android:textColor="#444444"
            android:textSize="12sp"
            android:textStyle="italic" />

        <GridLayout
            android:id="@+id/gridTabuleiro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:alignmentMode="alignMargins"
            android:background="#4737957F"
            android:columnCount="5"
            android:rowCount="5">

            <TextView android:id="@+id/num01" style="@style/EstiloBola" android:text="01" />
            <TextView android:id="@+id/num02" style="@style/EstiloBola" android:text="02" />
            <TextView android:id="@+id/num03" style="@style/EstiloBola" android:text="03" />
            <TextView android:id="@+id/num04" style="@style/EstiloBola" android:text="04" />
            <TextView android:id="@+id/num05" style="@style/EstiloBola" android:text="05" />
            <TextView android:id="@+id/num06" style="@style/EstiloBola" android:text="06" />
            <TextView android:id="@+id/num07" style="@style/EstiloBola" android:text="07" />
            <TextView android:id="@+id/num08" style="@style/EstiloBola" android:text="08" />
            <TextView android:id="@+id/num09" style="@style/EstiloBola" android:text="09" />
            <TextView android:id="@+id/num10" style="@style/EstiloBola" android:text="10" />
            <TextView android:id="@+id/num11" style="@style/EstiloBola" android:text="11" />
            <TextView android:id="@+id/num12" style="@style/EstiloBola" android:text="12" />
            <TextView android:id="@+id/num13" style="@style/EstiloBola" android:text="13" />
            <TextView android:id="@+id/num14" style="@style/EstiloBola" android:text="14" />
            <TextView android:id="@+id/num15" style="@style/EstiloBola" android:text="15" />
            <TextView android:id="@+id/num16" style="@style/EstiloBola" android:text="16" />
            <TextView android:id="@+id/num17" style="@style/EstiloBola" android:text="17" />
            <TextView android:id="@+id/num18" style="@style/EstiloBola" android:text="18" />
            <TextView android:id="@+id/num19" style="@style/EstiloBola" android:text="19" />
            <TextView android:id="@+id/num20" style="@style/EstiloBola" android:text="20" />
            <TextView android:id="@+id/num21" style="@style/EstiloBola" android:text="21" />
            <TextView android:id="@+id/num22" style="@style/EstiloBola" android:text="22" />
            <TextView android:id="@+id/num23" style="@style/EstiloBola" android:text="23" />
            <TextView android:id="@+id/num24" style="@style/EstiloBola" android:text="24" />
            <TextView android:id="@+id/num25" style="@style/EstiloBola" android:text="25" />
        </GridLayout>

        <EditText
            android:id="@+id/inputFixas"
            android:layout_width="360dp"
            android:layout_height="40dp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"
            android:background="#90FFFFFF"
            android:gravity="center"
            android:hint="Digite aqui seus números da sorte (ex.: 01 13 25)"
            android:inputType="text"
            android:textColor="#000000"
            android:textColorHint="#444444"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="5dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Switch
                    android:id="@+id/switchSoma"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="15dp"
                    android:checked="true"
                    android:text="Soma"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Switch
                    android:id="@+id/switchPrimos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="15dp"
                    android:checked="true"
                    android:text="Primos"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:textStyle="bold" />


                <Switch
                    android:id="@+id/switchPares"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="20dp"
                    android:checked="true"
                    android:text="Par/Ímp"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:orientation="horizontal">

                <Switch
                    android:id="@+id/switchFibonacci"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="15dp"
                    android:checked="true"
                    android:text="Fibo"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Switch
                    android:id="@+id/switchRepetidos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="15dp"
                    android:checked="true"
                    android:text="Repet."
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Switch
                    android:id="@+id/switchCiclo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Ciclo"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginBottom="5dp">

            <Button
                android:id="@+id/btnSortear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:backgroundTint="#C4B0276E"
                android:padding="12dp"
                android:text="Gerar Jogo"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnHistorico"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:backgroundTint="#9CD98407"
                android:text="Histórico"
                android:textSize="11sp"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnInserirManual"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:backgroundTint="#AB5A7D8E"
                android:text="+ Jogo"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/lblSomaPrimos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#55AAB9F4"
                android:gravity="center"
                android:padding="5dp"
                android:text="Soma: -- / Primos: --"
                android:textColor="#1D296A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/lblParesImpares"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:layout_weight="1"
                android:background="#7CC8E6C9"
                android:gravity="center"
                android:padding="5dp"
                android:text="Pares: -- / Ímpares: --"
                android:textColor="#1B5E20"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/lblFibRepetidos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:background="#4B878987"
            android:gravity="center"
            android:padding="5dp"
            android:text="Fib: -- / Rep: --"
            android:textColor="#030703"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lblCiclo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:background="#65FFEB3B"
            android:gravity="center"
            android:padding="3dp"
            android:text="Status do Ciclo: --"
            android:textColor="#7C4617"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtContador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"
            android:background="#2F5D215C"
            android:gravity="center"
            android:text="Jogos gerados: 0"
            android:textAlignment="center"
            android:textColor="#000000"
            android:textSize="12sp"
            android:textStyle="bold|italic" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnConferir"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="2dp"
                android:layout_weight="1"
                android:backgroundTint="#85B0276E"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Conferir"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="italic" />

            <Button
                android:id="@+id/btnVarredura"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="2dp"
                android:layout_weight="1"
                android:backgroundTint="#72FF5722"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Varred."
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="italic" />

            <Button
                android:id="@+id/btnCadastrarOficial"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="2dp"
                android:layout_weight="1"
                android:backgroundTint="#9C24978C"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Cadast."
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="italic" />

            <Button
                android:id="@+id/btnGerenciarManuais"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:backgroundTint="#AB5A7D8E"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Editar"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="italic" />
        </LinearLayout>

    </LinearLayout> <TextView
    android:id="@+id/txtAssinatura"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_alignParentTop="true"
    android:layout_alignParentEnd="true"
    android:layout_marginTop="25dp"
    android:layout_marginEnd="10dp"
    android:background="#7094784C"
    android:text="Criado por Liu..!"
    android:textColor="#000000"
    android:textSize="14sp"
    android:textStyle="bold|italic" />

</RelativeLayout>