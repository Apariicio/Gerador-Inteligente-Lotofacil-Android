<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_inicial"
    android:padding="16dp">

    <TextClock
        android:id="@+id/relogioDigital"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp"
        android:format12Hour="HH:mm:ss"
        android:format24Hour="HH:mm:ss"
        android:textColor="#333333"
        android:textSize="26sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/relogioDigital"
        android:layout_marginTop="5dp"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:background="#9991E5FA"
            android:text="Toque no volante para compartilhar"
            android:textColor="#444444"
            android:textSize="12sp"
            android:textStyle="italic" />

        <GridLayout
            android:id="@+id/gridTabuleiro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:alignmentMode="alignMargins"
            android:background="#3437957F"
            android:columnCount="5"
            android:rowCount="5">

            <TextView
                android:id="@+id/num01"
                style="@style/EstiloBola"
                android:text="01" />

            <TextView
                android:id="@+id/num02"
                style="@style/EstiloBola"
                android:text="02" />

            <TextView
                android:id="@+id/num03"
                style="@style/EstiloBola"
                android:text="03" />

            <TextView
                android:id="@+id/num04"
                style="@style/EstiloBola"
                android:text="04" />

            <TextView
                android:id="@+id/num05"
                style="@style/EstiloBola"
                android:text="05" />

            <TextView
                android:id="@+id/num06"
                style="@style/EstiloBola"
                android:text="06" />

            <TextView
                android:id="@+id/num07"
                style="@style/EstiloBola"
                android:text="07" />

            <TextView
                android:id="@+id/num08"
                style="@style/EstiloBola"
                android:text="08" />

            <TextView
                android:id="@+id/num09"
                style="@style/EstiloBola"
                android:text="09" />

            <TextView
                android:id="@+id/num10"
                style="@style/EstiloBola"
                android:text="10" />

            <TextView
                android:id="@+id/num11"
                style="@style/EstiloBola"
                android:text="11" />

            <TextView
                android:id="@+id/num12"
                style="@style/EstiloBola"
                android:text="12" />

            <TextView
                android:id="@+id/num13"
                style="@style/EstiloBola"
                android:text="13" />

            <TextView
                android:id="@+id/num14"
                style="@style/EstiloBola"
                android:text="14" />

            <TextView
                android:id="@+id/num15"
                style="@style/EstiloBola"
                android:text="15" />

            <TextView
                android:id="@+id/num16"
                style="@style/EstiloBola"
                android:text="16" />

            <TextView
                android:id="@+id/num17"
                style="@style/EstiloBola"
                android:text="17" />

            <TextView
                android:id="@+id/num18"
                style="@style/EstiloBola"
                android:text="18" />

            <TextView
                android:id="@+id/num19"
                style="@style/EstiloBola"
                android:text="19" />

            <TextView
                android:id="@+id/num20"
                style="@style/EstiloBola"
                android:text="20" />

            <TextView
                android:id="@+id/num21"
                style="@style/EstiloBola"
                android:text="21" />

            <TextView
                android:id="@+id/num22"
                style="@style/EstiloBola"
                android:text="22" />

            <TextView
                android:id="@+id/num23"
                style="@style/EstiloBola"
                android:text="23" />

            <TextView
                android:id="@+id/num24"
                style="@style/EstiloBola"
                android:text="24" />

            <TextView
                android:id="@+id/num25"
                style="@style/EstiloBola"
                android:text="25" />
        </GridLayout>

        <EditText
            android:id="@+id/inputFixas"
            android:layout_width="310dp"
            android:layout_height="30dp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"
            android:background="#90FFFFFF"
            android:gravity="center"
            android:hint="Digite aqui seus números da sorte (ex.: 01 13 25)"
            android:inputType="text"
            android:textColor="#000000"
            android:textColorHint="#444444"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="30dp"
            android:paddingEnd="30dp"
            android:layout_marginBottom="5dp">

            <Button
                android:id="@+id/btnSortear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:padding="12dp"
                android:text="Gerar Jogo"
                android:textAllCaps="true"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnHistorico"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#9CD98407"
                android:text="Histórico"
                android:textColor="#FFFFFF"
                android:textStyle="italic" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/lblSomaPrimos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#55AAB9F4"
                android:gravity="center"
                android:padding="5dp"
                android:text="Soma: -- / Primos: --"
                android:textColor="#1D296A"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/lblParesImpares"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:layout_weight="1"
                android:background="#7CC8E6C9"
                android:gravity="center"
                android:padding="5dp"
                android:text="Pares: -- / Ímpares: --"
                android:textColor="#1B5E20"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/lblFibRepetidos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:background="#4B878987"
            android:gravity="center"
            android:padding="5dp"
            android:text="Fib: -- / Rep: --"
            android:textColor="#030703"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lblCiclo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:background="#65FFEB3B"
            android:gravity="center"
            android:padding="3dp"
            android:text="Status do Ciclo: --"
            android:textColor="#7C4617"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtContador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"
            android:background="#2F5D215C"
            android:gravity="center"
            android:text="Jogos gerados: 0"
            android:textAlignment="center"
            android:textColor="#000000"
            android:textSize="12sp"
            android:textStyle="bold|italic" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnConferir"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="2dp"
                android:layout_weight="1"
                android:backgroundTint="#6A9C27B0"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Conferir"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="italic" />

            <Button
                android:id="@+id/btnVarredura"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="2dp"
                android:layout_weight="1"
                android:backgroundTint="#59FF5722"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Varred."
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="italic" />

            <Button
                android:id="@+id/btnCadastrarOficial"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="2dp"
                android:layout_weight="1"
                android:backgroundTint="#84009688"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Cadast."
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="italic" />

            <Button
                android:id="@+id/btnGerenciarManuais"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:backgroundTint="#AB607D8B"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Editar"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="italic" />
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/txtAssinatura"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="25dp"
        android:layout_marginEnd="10dp"
        android:background="#7094784C"
        android:text="Criado por Liu..!"
        android:textSize="14sp"
        android:textStyle="bold|italic" />

</RelativeLayout>